{
  "entities": {
    "business": {
      "title": "Business",
      "description": "A business entity.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "telegramId": { "type": "string" },
        "whatsappNumber": { "type": "string" }
      },
      "required": ["name"]
    },
    "reminder": {
      "title": "Reminder",
      "description": "A reminder entity.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "message": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "sent": { "type": "boolean" }
      },
      "required": ["businessId", "message", "scheduledAt"]
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "business",
      "description": "Collection of businesses."
    },
    "/reminders/{reminderId}": {
      "schema": "reminder",
      "description": "Collection of reminders."
    }
  }
}
