{
  "entities": {
    "business": {
      "title": "Business",
      "description": "Configuration and details for a business loyalty program.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the business." },
        "slogan": { "type": "string", "description": "Business slogan or catchphrase." },
        "description": { "type": "string", "description": "Detailed description of the business." },
        "rewardLongDescription": { "type": "string", "description": "Detailed description of the reward." },
        "logoUrl": { "type": "string", "description": "URL to the business logo image." },
        "rewardDescription": { "type": "string", "description": "Description of the reward (e.g., 'Free Coffee')." },
        "rewardImageUrl": { "type": "string", "description": "URL to the reward image." },
        "couponsNeeded": { "type": "integer", "description": "Number of coupons required for a reward." },
        "cooldownHours": { "type": "integer", "description": "Minimum hours between purchases." },
        "ownerEmail": { "type": "string", "description": "Email of the business owner." },
        "ownerUid": { "type": "string", "description": "Firebase Auth UID of the business owner." },
        "telegramChatId": { "type": "string", "description": "Telegram chat ID for notifications." },
        "telegramToken": { "type": "string", "description": "Telegram bot token." },
        "gmailUser": { "type": "string", "description": "Gmail address for sending notifications." },
        "gmailAppPass": { "type": "string", "description": "Gmail App Password." },
        "notificationsEnabled": { "type": "boolean", "description": "Whether notifications are enabled." },
        "currency": { "type": "string", "description": "Currency code (e.g., 'USD', 'ARS')." }
      },
      "required": ["name", "rewardDescription", "couponsNeeded", "cooldownHours"]
    },
    "customer": {
      "title": "Customer",
      "description": "Information about a customer participating in the loyalty program.",
      "type": "object",
      "properties": {
        "phone": { "type": "string", "description": "Customer's phone number (unique identifier)." },
        "name": { "type": "string", "description": "Customer's name." },
        "email": { "type": "string", "description": "Customer's email (optional)." },
        "notes": { "type": "string", "description": "Internal notes about the customer." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Customer status." },
        "couponsCount": { "type": "integer", "description": "Current number of coupons accumulated." },
        "totalSpent": { "type": "number", "description": "Total amount spent by the customer." },
        "lastPurchaseAt": { "type": "string", "format": "date-time", "description": "Timestamp of the last purchase." },
        "businessId": { "type": "string", "description": "ID of the business the customer belongs to." }
      },
      "required": ["phone", "businessId"]
    },
    "purchase": {
      "title": "Purchase",
      "description": "A record of a single purchase by a customer.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "ID of the customer who made the purchase." },
        "businessId": { "type": "string", "description": "ID of the business where the purchase was made." },
        "amount": { "type": "number", "description": "Amount of the purchase." },
        "paymentMethod": { "type": "string", "description": "Method of payment (e.g., 'Cash', 'Card')." },
        "notes": { "type": "string", "description": "Notes about the purchase." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the purchase occurred." }
      },
      "required": ["customerId", "businessId", "timestamp"]
    },
    "staff": {
      "title": "Staff",
      "description": "A staff member of a business.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Email of the staff member." },
        "name": { "type": "string", "description": "Name of the staff member." },
        "role": { "type": "string", "enum": ["staff", "admin"], "description": "Role of the staff member." },
        "businessId": { "type": "string", "description": "ID of the business the staff member belongs to." }
      },
      "required": ["email", "name", "role", "businessId"]
    },
    "reminder": {
      "title": "Reminder",
      "description": "A scheduled notification for customers.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string", "description": "ID of the business." },
        "subject": { "type": "string", "description": "Subject of the notification." },
        "message": { "type": "string", "description": "Message of the notification." },
        "scheduledAt": { "type": "string", "format": "date-time", "description": "When the notification is scheduled to be sent." },
        "customerIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of the customers to notify." },
        "status": { "type": "string", "enum": ["pending", "sent", "failed"], "description": "Current status of the reminder." },
        "statusMessage": { "type": "string", "description": "Optional error or status message." },
        "type": { "type": "string", "enum": ["marketing", "billing"], "description": "Type of reminder." }
      },
      "required": ["businessId", "subject", "message", "scheduledAt", "status", "type"]
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "business",
      "description": "Business configuration."
    },
    "/businesses/{businessId}/customers/{customerId}": {
      "schema": "customer",
      "description": "Customers for a specific business."
    },
    "/businesses/{businessId}/purchases/{purchaseId}": {
      "schema": "purchase",
      "description": "Purchase history for a specific business."
    },
    "/businesses/{businessId}/staff/{staffId}": {
      "schema": "staff",
      "description": "Staff members for a specific business."
    },
    "/businesses/{businessId}/reminders/{reminderId}": {
      "schema": "reminder",
      "description": "Scheduled reminders for a specific business."
    }
  }
}
