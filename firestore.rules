rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "marcorodolfo40@gmail.com" && request.auth.token.email_verified == true));
    }

    // Business configuration: Publicly readable for the customer panel, but only writable by admins.
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if isAdmin();

      // Customers: Admins can do everything. Customers can read/write their own data based on phone number.
      // Note: Since we use phone number as ID, we need to be careful.
      // For simplicity in this loyalty app, we'll allow public creation/update of customer records
      // but only if the phone number matches the document ID.
      match /customers/{customerId} {
        allow read: if true; // Customers need to see their progress
        allow write: if true; // Customers register themselves via phone
      }

      // Purchases: Admins can read/write. Customers can only create (register) a purchase.
      match /purchases/{purchaseId} {
        allow read: if isAdmin();
        allow create: if true; // Customers register purchases
        allow update, delete: if isAdmin();
      }

      match /reminders/{reminderId} {
        allow read, write: if isAdmin();
      }

      match /staff/{staffId} {
        allow read, write: if isAdmin();
      }
    }

    // User roles for admin access
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
